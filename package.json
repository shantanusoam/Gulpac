{
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./website/static/src/styles.css -o ./website/static/css/site.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./website/static/src/styles.css -o ./website/static/css/site.css --watch",
    "vendor:js": "cp node_modules/alpinejs/dist/cdn.min.js website/static/js/alpine.min.js",
    "dev": "npm run vendor:js && npm run watch:css",
    "build": "npm run vendor:js && npm run build:css",
    "deploy": "scripts/deploy.sh"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "agentation": "^3.0.2",
    "esbuild": "^0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "lucide": "^1.21.0",
    "motion": "^12.40.0"
  }
}